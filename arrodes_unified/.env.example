# =============================================================
# Arrodes Unified - Configuracao de Ambiente
# Copie para .env e preencha os valores
# =============================================================

# ── Discord ──────────────────────────────────────────────────
# Token do bot: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Prefixo de comandos (default: !)
BOT_PREFIX=!

# ── Google Gemini (Tier 1 - Little Arrodes) ──────────────────
# API Key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo principal (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ── Groq (Tier 2 - Arrodes Full / Klein AI) ─────────────────
# API Keys: https://console.groq.com/keys
# Suporta ate 3 keys para rotacao de rate limit
GROQ_KEY_1=your_groq_key_here
# GROQ_KEY_2=
# GROQ_KEY_3=

# Modelo Groq (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Limites de Uso (Free Tier Gemini) ────────────────────────
# MINUTE_REQUEST_LIMIT=15
# HOUR_REQUEST_LIMIT=300
# DAILY_REQUEST_LIMIT=1500
# DAILY_TOKEN_LIMIT=1000000

# Percentual de uso que ativa modo offline (default: 0.80 = 80%)
# USAGE_THRESHOLD=0.80

# ── Modo de Execucao ─────────────────────────────────────────
# little   = So Gemini (leve, rapido)
# arrodes  = So Groq (potente)
# combined = Ambos com roteamento inteligente
# MODE=combined

# ── API (modo combined) ──────────────────────────────────────
# Porta do servidor Flask interno
# TIER2_API_PORT=8080

# ── RAG ──────────────────────────────────────────────────────
# Peso do FAISS na busca hibrida (0.0-1.0, default: 0.7)
# RAG_ALPHA=0.7

# Threshold de confianca para roteamento (default: 0.6)
# RAG_CONFIDENCE_THRESHOLD=0.6

# ── Debug ────────────────────────────────────────────────────
# Mostra log de teste no Discord com requests restantes
# DISCORD_TEST_QUOTA_LOG=true
