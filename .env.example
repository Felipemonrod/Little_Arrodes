# Discord Bot Token - https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Google Gemini API Key - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Bot prefix (optional, default: !)
BOT_PREFIX=!

# Limites de uso da API (opcional - valores padrão do free tier)
# MINUTE_REQUEST_LIMIT=15
# HOUR_REQUEST_LIMIT=300
# DAILY_REQUEST_LIMIT=1500
# DAILY_TOKEN_LIMIT=1000000
# USAGE_THRESHOLD=0.80

# Mostrar log de teste no Discord com requests restantes (min/hora/dia)
# DISCORD_TEST_QUOTA_LOG=true
